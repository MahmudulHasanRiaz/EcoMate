generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_DATABASE_URL")
  extensions = [pg_trgm]
}

model Account {
  id                                         String              @id @default(cuid())
  name                                       String              @unique
  type                                       AccountType
  group                                      String?             // e.g. 'LIQUID' for payment-eligible accounts
  createdAt                                  DateTime            @default(now())
  updatedAt                                  DateTime            @updatedAt
  CourierPayment                             CourierPayment[]
  Expense_Expense_paidFromAccountIdToAccount Expense[]           @relation("Expense_paidFromAccountIdToAccount")
  Expense_Expense_payableAccountIdToAccount  Expense[]           @relation("Expense_payableAccountIdToAccount")
  ExpenseCategory                            ExpenseCategory[]
  LedgerEntry                                LedgerEntry[]
  Order_Order_paidFromAccountIdToAccount     Order[]             @relation("Order_paidFromAccountIdToAccount")
  Order_Order_shippingPaidAccountIdToAccount Order[]             @relation("Order_shippingPaidAccountIdToAccount")
  OrderPaymentEvent                          OrderPaymentEvent[]
  OrderTransaction                           OrderTransaction[]
  PurchasePayment                            PurchasePayment[]
  StaffPayment                               StaffPayment[]
  CashDrawer                                 CashDrawer?
  CutoffSettlement                           CutoffSettlement[]
}

model AppSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AttendanceRecord {
  id                 String           @id @default(cuid())
  staffId            String
  date               DateTime         @db.Date
  status             AttendanceStatus
  checkInTime        DateTime?
  checkOutTime       DateTime?
  expectedMinutes    Int?
  totalWorkDuration  Int?
  totalBreakDuration Int?
  totalInactiveDuration Int? @default(0)
  isWeekend          Boolean          @default(false)
  isHoliday          Boolean          @default(false)
  overtimeMinutes    Int?
  overtimeBonusAmount Float?          @default(0)
  leaveRequestId     String?
  staff              StaffMember      @relation(fields: [staffId], references: [id], onDelete: Cascade)
  leaveRequest       LeaveRequest?    @relation(fields: [leaveRequestId], references: [id])
  breaks             BreakRecord[]
  inactiveRecords    AttendanceInactiveRecord[]
  editLogs           AttendanceEditLog[]

  @@unique([staffId, date])
  @@index([date])
  @@index([leaveRequestId])
}

model Attribute {
  id        String   @id @default(cuid())
  name      String
  options   String[]
  productId String
  Product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, name])
}

model BreakRecord {
  id               String           @id @default(cuid())
  attendanceId     String
  startTime        DateTime
  endTime          DateTime?
  AttendanceRecord AttendanceRecord @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
}

model AttendanceInactiveRecord {
  id               String           @id @default(cuid())
  attendanceId     String
  startTime        DateTime
  endTime          DateTime?
  AttendanceRecord AttendanceRecord @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
}

model Business {
  id                     String                   @id @default(cuid())
  name                   String                   @unique
  logo                   String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  address                String?
  phone                  String?
  CourierIntegration     CourierIntegration[]
  CourierPayment         CourierPayment[]
  Expense                Expense[]
  LedgerEntry            LedgerEntry[]
  MarketingAttribution   MarketingAttribution[]
  MarketingCampaign      MarketingCampaign[]
  MarketingSpend         MarketingSpend[]
  Order                  Order[]
  OrderFinancialSnapshot OrderFinancialSnapshot[]
  OrderPaymentEvent      OrderPaymentEvent[]
  OrderTransaction       OrderTransaction[]
  OrderRestriction       OrderRestriction[]
  WooCheckoutLead        WooCheckoutLead[]
  WooCommerceIntegration WooCommerceIntegration[]
  StaffMember            StaffMember[]            @relation("StaffBusinessAccess")
  CashDrawer             CashDrawer[]
  CashDrawerTransfer     CashDrawerTransfer[]
}

model Category {
  id              String            @id @default(cuid())
  name            String            @unique
  parentId        String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  Category        Category?         @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_Category  Category[]        @relation("CategoryToCategory")
  Product         Product[]
  ProductCategory ProductCategory[] @relation("ProductCategoryToCategory")
}

model ProductCategory {
  productId  String
  categoryId String
  Product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  Category   Category @relation("ProductCategoryToCategory", fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

model CheckPassingItem {
  id             String             @id @default(cuid())
  source         CheckPassingSource
  sourceId       String
  passingDate    DateTime
  amount         Float
  status         CheckStatus
  checkNo        String?
  referenceId    String?
  referenceLabel String?
  referenceUrl   String?
  payee          String?
  type           String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([source, sourceId])
  @@index([checkNo])
  @@index([passingDate, source, id])
  @@index([passingDate, status])
  @@index([payee])
  @@index([referenceLabel])
  @@index([source, sourceId])
}

model CheckPassingLog {
  id             String       @id @default(cuid())
  source         String
  sourceId       String
  previousStatus CheckStatus?
  newStatus      CheckStatus
  note           String?
  userName       String
  userId         String?
  createdAt      DateTime     @default(now())

  @@index([createdAt])
  @@index([source, sourceId])
}

model ComboProductItem {
  parentId  String
  childId   String
  variantId String?
  id        Int             @id @default(autoincrement())
  child     Product         @relation("ComboProductItem_childIdToProduct", fields: [childId], references: [id], onDelete: Cascade)
  parent    Product         @relation("ComboProductItem_parentIdToProduct", fields: [parentId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([parentId, childId, variantId])
}

model CourierDispatchLog {
  id              String         @id @default(cuid())
  orderId         String
  businessId      String?
  courierName     CourierService
  status          String
  message         String?
  requestPayload  Json?
  responsePayload Json?
  createdAt       DateTime       @default(now())
  Order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([orderId])
}

model CourierIntegration {
  id           String         @id @default(cuid())
  businessId   String
  courierName  CourierService
  status       String
  credentials  Json
  deliveryType Int?
  itemType     Int?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  Business     Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, courierName])
}

model CourierPayment {
  id                String                  @id @default(cuid())
  courierService    String
  businessId        String
  amount            Float
  paymentDate       DateTime
  referenceNo       String?
  note              String?
  createdBy         String
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  direction         CourierPaymentDirection @default(Received)
  receivedAccountId String?
  Business          Business                @relation(fields: [businessId], references: [id])
  Account           Account?                @relation(fields: [receivedAccountId], references: [id])

  @@index([courierService, businessId, paymentDate])
}

model Customer {
  id              String            @id @default(cuid())
  name            String
  email           String?
  phone           String            @unique
  joinDate        DateTime
  address         String
  district        String
  country         String
  ip              String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  CustomerAddress CustomerAddress[]
  Order           Order[]
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  address    String
  district   String
  country    String
  isDefault  Boolean  @default(false)
  lastUsedAt DateTime @default(now())
  Customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Expense {
  id                                         String                @id @default(cuid())
  date                                       DateTime
  amount                                     Float
  notes                                      String?
  isAdExpense                                Boolean               @default(false)
  platform                                   OrderPlatform?
  createdAt                                  DateTime              @default(now())
  updatedAt                                  DateTime              @updatedAt
  categoryId                                 String
  businessId                                 String?
  isPaid                                     Boolean               @default(true)
  paidAt                                     DateTime?
  paidFromAccountId                          String?
  payableAccountId                           String?
  staffPaymentId                             String?               @unique
  check                                      Float                 @default(0)
  checkDate                                  DateTime?
  checkStatus                                CheckStatus?
  checkNo                                    String?
  approvalStatus                             ExpenseApprovalStatus @default(Approved)
  submittedById                              String?
  submittedByName                            String?
  submittedAt                                DateTime?
  approvedById                               String?
  approvedByName                             String?
  approvedAt                                 DateTime?
  rejectedById                               String?
  rejectedByName                             String?
  rejectedAt                                 DateTime?
  rejectionNote                              String?
  paidById                                   String?
  paidByName                                 String?
  branchId                                   String?
  Business                                   Business?             @relation(fields: [businessId], references: [id])
  ExpenseCategory                            ExpenseCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  Account_Expense_paidFromAccountIdToAccount Account?              @relation("Expense_paidFromAccountIdToAccount", fields: [paidFromAccountId], references: [id])
  Account_Expense_payableAccountIdToAccount  Account?              @relation("Expense_payableAccountIdToAccount", fields: [payableAccountId], references: [id])
  StaffPayment                               StaffPayment?         @relation(fields: [staffPaymentId], references: [id])
  Branch                                     Branch?               @relation(fields: [branchId], references: [id])

  @@index([businessId, date])
  @@index([categoryId, date])
  @@index([checkDate, checkStatus])
  @@index([checkNo])
  @@index([isAdExpense, date])
  @@index([branchId, date])
}

model ExpenseCategory {
  id               String    @id @default(cuid())
  name             String    @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  expenseAccountId String?
  Expense          Expense[]
  Account          Account?  @relation(fields: [expenseAccountId], references: [id])
}

model Branch {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Expense   Expense[]
}

model ExportJob {
  id          String          @id @default(cuid())
  type        ExportJobType
  status      ExportJobStatus @default(Queued)
  createdById String?
  businessId  String?
  params      Json?
  filePath    String?
  fileName    String?
  error       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  completedAt DateTime?
}

model FabricLotUsage {
  id                String            @id @default(cuid())
  poId              String
  itemId            String
  part              FabricPart
  inventoryItemId   String
  yards             Int
  unitCost          Float             @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  InventoryItem     InventoryItem     @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  PurchaseOrderItem PurchaseOrderItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  PurchaseOrder     PurchaseOrder     @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId])
  @@index([itemId])
  @@index([poId])
}

model InventoryItem {
  id                   String                 @id @default(cuid())
  productId            String
  variantId            String?
  locationId           String
  quantity             Int
  lotNumber            String
  receivedDate         DateTime
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  unitCost             Float                  @default(0)
  reservedQuantity     Int                    @default(0)
  FabricLotUsage       FabricLotUsage[]
  StockLocation        StockLocation          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  Product              Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  ProductVariant       ProductVariant?        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  InventoryMovement    InventoryMovement[]
  OrderStockAllocation OrderStockAllocation[]
  ProductionStep       ProductionStep[]

  @@unique([productId, variantId, locationId, lotNumber])
  @@index([productId, variantId])
  @@index([productId, variantId, locationId])
}

model InventoryMovement {
  id              String                @id @default(cuid())
  inventoryItemId String
  type            InventoryMovementType
  quantityChange  Int
  balance         Int
  notes           String?
  user            String
  reference       String?
  timestamp       DateTime              @default(now())
  InventoryItem   InventoryItem         @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  StockTransfer   StockTransfer?        @relation(fields: [reference], references: [id])

  @@index([timestamp])
}

model Issue {
  id          String        @id @default(cuid())
  orderId     String?
  title       String
  description String
  status      IssueStatus   @default(Open)
  priority    IssuePriority @default(Medium)
  createdBy   String
  assignedTo  String?
  createdAt   DateTime      @default(now())
  resolvedAt  DateTime?
  StaffMember StaffMember?  @relation(fields: [assignedTo], references: [id])
  Order       Order?        @relation(fields: [orderId], references: [id])
  IssueLog    IssueLog[]

  @@index([assignedTo])
  @@index([orderId])
  @@index([priority])
  @@index([status])
}

model IssueLog {
  id        String   @id @default(cuid())
  issueId   String
  timestamp DateTime @default(now())
  user      String
  action    String
  Issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

model LedgerEntry {
  id                  String    @id @default(cuid())
  date                DateTime
  description         String
  sourceTransactionId String
  accountId           String
  debit               Float
  credit              Float
  createdAt           DateTime  @default(now())
  businessId          String?
  entryNumber         String?
  postingGroup        String?
  snapshotId          String?
  Account             Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  Business            Business? @relation(fields: [businessId], references: [id])

  @@unique([postingGroup, accountId])
  @@index([accountId, date])
  @@index([businessId, date])
  @@index([entryNumber])
  @@index([postingGroup])
  @@index([snapshotId])
  @@index([sourceTransactionId])
}

model LedgerEntrySequence {
  id         String   @id @default(cuid())
  dateKey    String   @unique
  lastNumber Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MarketingAttribution {
  id                String            @id @default(cuid())
  campaignId        String
  orderId           String
  businessId        String?
  marketerId        String?
  attributedAt      DateTime          @default(now())
  Business          Business?         @relation(fields: [businessId], references: [id])
  MarketingCampaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  StaffMember       StaffMember?      @relation(fields: [marketerId], references: [id])
  Order             Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([campaignId, orderId])
  @@index([businessId])
  @@index([marketerId])
}

model MarketingCampaign {
  id                   String                 @id @default(cuid())
  name                 String
  businessId           String?
  marketerId           String?
  trackedProductIds    String[]               @default([])
  channel              String?
  objective            String?
  status               String?
  budget               Float                  @default(0)
  startDate            DateTime?              @db.Date
  endDate              DateTime?              @db.Date
  notes                String?
  shortCode            String?                @unique
  targetCpr            Float?
  maxCpr               Float?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  MarketingAttribution MarketingAttribution[]
  Business             Business?              @relation(fields: [businessId], references: [id])
  StaffMember          StaffMember?           @relation(fields: [marketerId], references: [id])
  MarketingSpend       MarketingSpend[]

  @@index([businessId, status])
  @@index([marketerId])
  @@index([startDate, endDate])
}

model MarketingSpend {
  id                String            @id @default(cuid())
  campaignId        String
  businessId        String?
  date              DateTime          @db.Date
  amount            Float
  notes             String?
  createdById       String?
  expenseId         String?
  createdAt         DateTime          @default(now())
  Business          Business?         @relation(fields: [businessId], references: [id])
  MarketingCampaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  StaffMember       StaffMember?      @relation(fields: [createdById], references: [id])

  @@index([businessId, date])
  @@index([campaignId, date])
}

model Notification {
  id          String           @id @default(cuid())
  staffId     String
  title       String
  description String
  time        DateTime         @default(now())
  read        Boolean          @default(false)
  href        String
  icon        NotificationIcon @default(Bell)
  StaffMember StaffMember      @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, read])
  @@index([time])
}

model Order {
  id                                           String                  @id @default(cuid())
  customerName                                 String
  customerEmail                                String?
  customerPhone                                String
  date                                         DateTime
  status                                       OrderStatus
  total                                        Float
  shipping                                     Float?
  discount                                     Float?
  customerNote                                 String?
  officeNote                                   String?
  createdBy                                    String?
  confirmedBy                                  String?
  businessId                                   String?
  businessName                                 String?
  businessLogo                                 String?
  paymentMethod                                PaymentMethod
  paidAmount                                   Float
  createdAt                                    DateTime                @default(now())
  updatedAt                                    DateTime                @updatedAt
  shippingAddress                              Json?
  assignedToId                                 String?
  orderDay                                     String?
  orderNumber                                  String?                 @unique
  orderSerial                                  Int?
  courierConsignmentId                         String?
  courierDispatchedAt                          DateTime?
  courierMeta                                  Json?
  courierService                               CourierService?
  courierStatus                                String?
  courierTrackingCode                          String?
  rawPayload                                   Json?
  source                                       String?
  platform                                     String?
  transactionId                                String?
  senderPhone                                  String?
  actualCodAmount                              Float?
  courierChargesSource                         CourierChargesSource    @default(Config)
  chargesLastUpdated                           DateTime?
  chargesUpdatedBy                             String?
  courierCodCharge                             Float?
  courierDeliveryCharge                        Float?
  courierNetPayable                            Float?
  isStockDeducted                              Boolean                 @default(false)
  isStockReserved                              Boolean                 @default(false)
  stockReservedFrom                            String?
  exchangeSourceOrderId                        String?
  isExchange                                   Boolean                 @default(false)
  parentOrderId                                String?
  type                                         OrderType               @default(REGULAR)
  allocatedDiscount                            Float?
  allocatedShipping                            Float?
  allocatedSubtotal                            Float?
  paidFromAccountId                            String?
  shippingPaid                                 Boolean                 @default(false)
  shippingPaidAccountId                        String?
  shippingPaidAmount                           Float                   @default(0)
  ipHash                                       String?
  statusUpdatedAt                              DateTime?
  isDeleted                                    Boolean                 @default(false)
  deletedAt                                    DateTime?
  deletedById                                  String?
  deleteNote                                   String?
  showroomId                                   String?
  CourierDispatchLog                           CourierDispatchLog[]
  Issue                                        Issue[]
  MarketingAttribution                         MarketingAttribution[]
  assignedTo                                   StaffMember?            @relation(fields: [assignedToId], references: [id])
  Business                                     Business?               @relation(fields: [businessId], references: [id])
  Customer                                     Customer                @relation(fields: [customerPhone], references: [phone], onDelete: SetNull)
  Account_Order_paidFromAccountIdToAccount     Account?                @relation("Order_paidFromAccountIdToAccount", fields: [paidFromAccountId], references: [id])
  Order                                        Order?                  @relation("OrderToOrder", fields: [parentOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_Order                                  Order[]                 @relation("OrderToOrder")
  Account_Order_shippingPaidAccountIdToAccount Account?                @relation("Order_shippingPaidAccountIdToAccount", fields: [shippingPaidAccountId], references: [id])
  Showroom                                     Showroom?               @relation(fields: [showroomId], references: [id])
  OrderFinancialSnapshot                       OrderFinancialSnapshot?
  OrderLog                                     OrderLog[]
  OrderPaymentEvent                            OrderPaymentEvent[]
  OrderTransaction                             OrderTransaction[] @relation("OrderTransactions")
  products                                     OrderProduct[]
  OrderStockAllocation                         OrderStockAllocation[]
  StaffIncome                                  StaffIncome[]
  WebhookFailure                               WebhookFailure[]

  @@index([businessId, date])
  @@index([businessId])
  @@index([businessId, status, date])
  @@index([courierService, status, courierDispatchedAt])
  @@index([createdAt])
  @@index([customerName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([customerPhone(ops: raw("gin_trgm_ops"))], map: "Order_customerPhone_gin_idx", type: Gin)
  @@index([customerPhone])
  @@index([isDeleted])
  @@index([orderDay, orderSerial])
  @@index([orderNumber(ops: raw("gin_trgm_ops"))], map: "Order_orderNumber_gin_idx", type: Gin)
  @@index([platform])
  @@index([showroomId])
  @@index([status, date])
}

model OrderFinancialSnapshot {
  id                String    @id @default(cuid())
  orderId           String    @unique
  businessId        String?
  statusAtSnapshot  String
  revenue           Float     @default(0)
  cogs              Float     @default(0)
  courierExpense    Float     @default(0)
  courierReceivable Float     @default(0)
  courierPayable    Float     @default(0)
  cashReceived      Float     @default(0)
  returnFeeRevenue  Float     @default(0)
  netProfit         Float     @default(0)
  cogsEstimated     Boolean   @default(false)
  computedAt        DateTime  @default(now())
  Business          Business? @relation(fields: [businessId], references: [id])
  Order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model OrderLog {
  id          String       @id @default(cuid())
  orderId     String
  title       String
  description String
  user        String
  timestamp   DateTime     @default(now())
  meta        Json?
  userId      String?
  Order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  StaffMember StaffMember? @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
}

model OrderPaymentEvent {
  id         String    @id @default(cuid())
  orderId    String
  businessId String?
  eventType  String
  amount     Float
  accountId  String?
  createdAt  DateTime  @default(now())
  Account    Account?  @relation(fields: [accountId], references: [id])
  Business   Business? @relation(fields: [businessId], references: [id])
  Order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([orderId])
}

model OrderProduct {
  id                 String   @id @default(cuid())
  orderId            String
  productId          String
  quantity           Int
  price              Float
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  sku                String?
  variantId          String?
  siteDiscount       Float    @default(0)
  componentBreakdown Json?
  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId, productId])
}

model OrderRestriction {
  id                     String                  @id @default(cuid())
  targetType             String
  targetHash             String
  scope                  String
  integrationId          String?
  businessId             String?
  message                String?
  supportPhone           String?
  expiresAt              DateTime?
  createdByStaffId       String?
  sourceOrderId          String?
  sourceCustomerId       String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  Business               Business?               @relation(fields: [businessId], references: [id])
  StaffMember            StaffMember?            @relation(fields: [createdByStaffId], references: [id])
  WooCommerceIntegration WooCommerceIntegration? @relation(fields: [integrationId], references: [id])

  @@index([expiresAt])
  @@index([integrationId])
  @@index([scope])
  @@index([targetHash, targetType])
}

model OrderStockAllocation {
  id              String        @id @default(cuid())
  orderId         String
  inventoryItemId String
  productId       String
  variantId       String?
  quantity        Int
  unitCost        Float         @default(0)
  totalCost       Float         @default(0)
  action          String
  createdAt       DateTime      @default(now())
  InventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  Order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId])
  @@index([orderId])
}

model Product {
  id                    String              @id @default(cuid())
  name                  String
  description           String?
  price                 Float
