  oldCheckIn   DateTime?
  newCheckIn   DateTime?
  oldCheckOut  DateTime?
  newCheckOut  DateTime?
  oldStatus    String?
  newStatus    String?
  oldInactiveDuration Int?
  newInactiveDuration Int?
  oldOvertimeMinutes  Int?
  newOvertimeMinutes  Int?
  createdAt    DateTime         @default(now())
  attendance   AttendanceRecord @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  editedBy     StaffMember      @relation("AttendanceEditedBy", fields: [editedById], references: [id])

  @@index([attendanceId])
}


enum CourierChargesSource {
  Config
  Invoice
}

model CourierInvoice {
  id              String               @id @default(cuid())
  courierService  String
  invoiceNumber   String
  invoiceDate     DateTime?
  businessId      String?
  totalRows       Int                  @default(0)
  matchedRows     Int                  @default(0)
  mismatchRows    Int                  @default(0)
  totalCollected  Float                @default(0)
  totalFee        Float                @default(0)
  totalBilled     Float                @default(0)
  importedBy      String
  importedAt      DateTime             @default(now())
  
  items           CourierInvoiceItem[]

  @@unique([invoiceNumber, courierService])
  @@index([courierService])
  @@index([businessId])
}

model CourierInvoiceItem {
  id                    String         @id @default(cuid())
  invoiceId             String
  orderId               String?
  orderNumber           String?
  consignmentId         String?

  collectableAmount     Float?
  collectedAmount       Float?
  codFee                Float?
  deliveryFee           Float?
  additionalCharge      Float?
  discount              Float?
  totalFee              Float?
  billingAmount         Float?

  deliveryStatus        String?
  paymentStatus         String?
  payoutMethod          String?
  createdDate           DateTime?
  deliveredDate         DateTime?
  invoicedDate          DateTime?

  mismatchReason        String?
  dueMismatchAmount     Float?
  billingMismatchAmount Float?

  raw                   Json?          // Stores the exact row from CSV

  invoice               CourierInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([orderNumber])
  @@index([consignmentId])
}

model CashDrawer {
  id          String   @id @default(cuid())
  name        String
  accountId   String   @unique
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  businessId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  Account     Account  @relation(fields: [accountId], references: [id], onDelete: NoAction)
  Business    Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  CreatedBy   StaffMember? @relation("CashDrawerCreator", fields: [createdById], references: [id], onDelete: SetNull)

  TransfersOut CashDrawerTransfer[] @relation("TransfersFrom")
  TransfersIn  CashDrawerTransfer[] @relation("TransfersTo")

  Showroom     Showroom?
  Sessions     CashDrawerSession[]
  Adjustments  CashDrawerAdjustment[]

  @@index([businessId])
}

model CashDrawerTransfer {
  id           String   @id @default(cuid())
  fromDrawerId String
  toDrawerId   String
  amount       Float
  notes        String?
  postingGroup String
  businessId   String?
  createdAt    DateTime @default(now())
  createdById  String?

  FromDrawer   CashDrawer @relation("TransfersFrom", fields: [fromDrawerId], references: [id], onDelete: NoAction)
  ToDrawer     CashDrawer @relation("TransfersTo", fields: [toDrawerId], references: [id], onDelete: NoAction)
  Business     Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  CreatedBy    StaffMember? @relation("CashDrawerTransferCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([fromDrawerId])
  @@index([toDrawerId])
}

model Showroom {
  id                 String   @id @default(cuid())
  name               String   @unique
  locationId         String   @unique
  cashDrawerId       String   @unique
  defaultInvoiceNote String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  StockLocation      StockLocation @relation(fields: [locationId], references: [id])
  CashDrawer         CashDrawer    @relation(fields: [cashDrawerId], references: [id])
  Accesses           ShowroomAccess[]
  Orders             Order[]
}

model ShowroomAccess {
  id                 String   @id @default(cuid())
  showroomId         String
  staffId            String
  createdAt          DateTime @default(now())

  Showroom           Showroom     @relation(fields: [showroomId], references: [id], onDelete: Cascade)
  StaffMember        StaffMember  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([showroomId, staffId])
}

model CashDrawerSession {
  id                 String   @id @default(cuid())
  cashDrawerId       String
  openedById         String?
  closedById         String?
  openedAt           DateTime @default(now())
  closedAt           DateTime?
  openingBalance     Float
  closingBalance     Float?
  status             String   @default("Open")
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  CashDrawer         CashDrawer   @relation(fields: [cashDrawerId], references: [id])
  OpenedBy           StaffMember? @relation("SessionOpenedBy", fields: [openedById], references: [id])
  ClosedBy           StaffMember? @relation("SessionClosedBy", fields: [closedById], references: [id])

  @@index([cashDrawerId])
}

model CashDrawerAdjustment {
  id                 String   @id @default(cuid())
  cashDrawerId       String
  createdById        String?
  amount             Float
  reason             String
  postingGroup       String
  createdAt          DateTime @default(now())

  CashDrawer         CashDrawer   @relation(fields: [cashDrawerId], references: [id])
  CreatedBy          StaffMember? @relation("AdjustmentCreatedBy", fields: [createdById], references: [id])

  @@index([cashDrawerId])
}

model OrderTransaction {
  id              String   @id @default(cuid())
  orderId         String
  businessId      String?
  amount          Float
  paymentMethod   PaymentMethod
  paymentType     String?  // e.g., "Full", "Partial"
  reference       String?  // Phone / Tnx ID / Bank Ac number
  status          String   @default("Pending") // Pending, Approved, Rejected
  accountId       String?  // The account to deposit into
  
  createdBy       String?
  approvedBy      String?
  rejectedBy      String?
  approvedAt      DateTime?
  rejectedAt      DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  Order           Order    @relation("OrderTransactions", fields: [orderId], references: [id], onDelete: Cascade)
  Business        Business? @relation(fields: [businessId], references: [id])
  Account         Account? @relation(fields: [accountId], references: [id])
  StaffCreator    StaffMember? @relation("CreatedTransactions", fields: [createdBy], references: [id])
  StaffApprover   StaffMember? @relation("ApprovedTransactions", fields: [approvedBy], references: [id])
  StaffRejecter   StaffMember? @relation("RejectedTransactions", fields: [rejectedBy], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([businessId])
}

// ─── Cut-Off Accounting Boundary ───────────────────────────────────

enum CutoffStatus {
  DRAFT
  VALIDATED
  APPLIED
  SUPERSEDED
}

model CutoffRevision {
  id                     String       @id @default(cuid())
  revisionNumber         Int          @default(1)
  cutoffDate             DateTime     @db.Date
  status                 CutoffStatus @default(DRAFT)
  notes                  String?

  // Validation
  validatedAt            DateTime?
  validationReport       Json?

  // Application
  appliedAt              DateTime?
  appliedById            String?
  appliedByName          String?

  // Supersession
  supersededAt           DateTime?
  supersededById         String?
  supersededByRevisionId String?

  // Audit
  createdById            String?
  createdByName          String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  OpeningBalance           OpeningBalance[]
  OpeningInventorySnapshot OpeningInventorySnapshot[]
  OpeningWipEntry          OpeningWipEntry[]
  CutoffSettlement         CutoffSettlement[]
  AuditLog                 CutoffAuditLog[]

  @@index([status])
  @@index([cutoffDate])
}

model OpeningBalance {
  id              String   @id @default(cuid())
  revisionId      String
  entityType      String   // 'supplier' | 'vendor' | 'customer' | 'staff' | 'account'
  entityId        String
  entityName      String   // Denormalized for readability

  suggestedAmount Float    @default(0)
  finalAmount     Float    @default(0)
  isOverridden    Boolean  @default(false)
  overrideReason  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  CutoffRevision  CutoffRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@unique([revisionId, entityType, entityId])
  @@index([revisionId])
  @@index([entityType, entityId])
}

model CutoffSettlement {
  id                 String          @id @default(cuid())
  revisionId         String
  entityType         String          // 'supplier' | 'vendor'
  entityId           String          // supplierId or vendorId

  cash               Float           @default(0)
  check              Float           @default(0)
  checkDate          DateTime?
  checkStatus        CheckStatus?
  checkNo            String?
  paidFromAccountId  String?
  paymentMethod      String?

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  CutoffRevision     CutoffRevision  @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  Account            Account?        @relation(fields: [paidFromAccountId], references: [id])

  @@index([revisionId])
  @@index([entityType, entityId])
  @@index([checkDate, checkStatus])
}

model OpeningInventorySnapshot {
  id              String   @id @default(cuid())
  revisionId      String
  productId       String
  variantId       String?

  totalQuantity   Int      @default(0)
  totalValue      Float    @default(0)
  lotCount        Int      @default(1)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  CutoffRevision  CutoffRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  Lots            OpeningInventoryLot[]

  @@unique([revisionId, productId, variantId])
  @@index([revisionId])
}

model OpeningInventoryLot {
  id              String   @id @default(cuid())
  snapshotId      String
  lotNumber       String
  quantity        Int      @default(0)
  unitCost        Float    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  OpeningInventorySnapshot OpeningInventorySnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
}

model OpeningWipEntry {
  id              String   @id @default(cuid())
  revisionId      String
  productId       String
  variantId       String?
  currentStep     String   // PLANNING | FABRIC | PRINTING | CUTTING
  quantity        Int      @default(0)
  estimatedCost   Float    @default(0)
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  CutoffRevision  CutoffRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@unique([revisionId, productId, variantId, currentStep])
  @@index([revisionId])
}

model CutoffAuditLog {
  id              String   @id @default(cuid())
  revisionId      String
  action          String   // CREATED | VALIDATED | APPLIED | SUPERSEDED | BALANCE_OVERRIDDEN | LOT_EDITED
  detail          Json?
  performedById   String?
  performedByName String?
  createdAt       DateTime @default(now())

  CutoffRevision  CutoffRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@index([revisionId])
  @@index([createdAt])
}
