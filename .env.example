# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ecomate"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/ecomate"

# App URLs
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Revalidation & Cron
REVALIDATION_TOKEN=your_random_token
CRON_SECRET=your_random_secret

# SMS (MIM SMS)
MIM_SMS_USERNAME=your_username
MIM_SMS_API_KEY=your_api_key
MIM_SMS_SENDER_NAME=your_sender_name

# Redis (optional, required for BullMQ worker)
# REDIS_URL=redis://localhost:6379
# REDIS_USERNAME=default
# REDIS_PASSWORD=your_redis_password
# REDIS_DB=0

# AWS S3 (optional, required for file uploads)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=ap-southeast-1
# AWS_S3_BUCKET=your_bucket_name

# Genkit AI (optional)
# GOOGLE_GENAI_API_KEY=your_api_key