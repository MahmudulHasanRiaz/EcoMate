# Portainer Environment Variables (Use "Load from file")

# Postgres (internal service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=ecomate

DATABASE_URL=postgres://postgres:your_password@postgres:5432/ecomate
DIRECT_DATABASE_URL=postgres://postgres:your_password@postgres:5432/ecomate

# App URLs
APP_URL=https://your-app-url.com
NEXT_PUBLIC_APP_URL=https://your-app-url.com
NEXT_PUBLIC_API_URL=https://your-app-url.com

# Clerk Credentials
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_publishable_key
CLERK_SECRET_KEY=sk_live_your_secret_key
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret

# Optional but useful
REVALIDATION_TOKEN=your_revalidation_token
CRON_SECRET=your_random_secret

# SMS (if enabled)
MIM_SMS_USERNAME=your_sms_user
MIM_SMS_API_KEY=your_sms_key
MIM_SMS_SENDER_NAME=YOURMASK
